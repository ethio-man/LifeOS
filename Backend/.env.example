DATABASE_URL=postgresql://lifeos:lifeos_secret@localhost:5432/lifeos

# Supabase + Vercel: do not use the "Direct connection" URI (db.PROJECT.supabase.co:5432) on the
# backend — it often returns P1001 from serverless. Copy "Transaction pooler" / Session pooler
# from Dashboard → Connect (host ends with pooler.supabase.com, port 6543 for transaction mode).
# Append &pgbouncer=true (Prisma + transaction pooler). Example shape:
# postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

JWT_SECRET=your-jwt-secret-key-change-this
ADMIN_PASSWORD=admin123
PORT=3001
